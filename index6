      if(id==='m-phone') $('ms-phone').value=DATA.phone||'';
      if(id==='m-email') $('ms-email').value=DATA.email||'';
      if(id==='m-devise') $('ms-devise').value=DATA.devise||'FCFA';
      if(id==='m-tax') $('ms-tax').value=DATA.tax||0;
      if(id==='m-objectif') $('ms-objectif').value=DATA.objectifCA||'';
      if(id==='m-seuil') $('ms-seuil').value=DATA.seuilRent||'';
      if(id==='m-marge') $('ms-marge').value=DATA.margeTarget||30;
      if(id==='m-stock-seuil') $('ms-stock-seuil').value=DATA.stockSeuil||5;
    },50);
  });

  // Recherche
  $('search-input')?.addEventListener('keydown',e=>{ if(e.key==='Enter') doSearch($('search-input').value); });
  $('mob-search-input')?.addEventListener('keydown',e=>{ if(e.key==='Enter'){ doSearch($('mob-search-input').value); $('mob-search-overlay').classList.remove('on'); } });

  // Vente produit change
  $('v-prod')?.addEventListener('change',onVenteProdChange);

  // Caisse search
  $('caisse-search')?.addEventListener('input',renderCaisseProds);
  $('caisse-cat')?.addEventListener('change',renderCaisseProds);
  $('caisse-remise')?.addEventListener('input',renderCart);

  // Historique année change
  $('hist-year')?.addEventListener('change',renderHistorique);

  // Échap pour fermer modales
  document.addEventListener('keydown',e=>{ if(e.key==='Escape') document.querySelectorAll('.mo.on').forEach(m=>m.classList.remove('on')); });

  // Init app
  loadSettingsUI();
  buildCatSelect();
  renderProdFilters();
  goTo('dashboard');
  setTimeout(updateSalesChart,300);
}

// Démarrage
if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init);
else init();
</script>
</body>
</html>
