/* ════════════════════════════════════════
   ÉVÉNEMENTS — DÉLÉGATION GLOBALE
   Tout passe par addEventListener — pas d'onclick inline
════════════════════════════════════════ */
function handleAction(e){
  // Chercher l'élément cliquable le plus proche
  const t=e.target;
  const btn=t.closest('[data-action],[data-modal],[data-close],[data-page],[data-pf],[data-vf],[data-pm],[data-reset]');
  if(!btn) return;

  const action=btn.dataset.action;
  const modal=btn.dataset.modal;
  const close=btn.dataset.close;
  const page=btn.dataset.page;
  const pf=btn.dataset.pf;
  const vf=btn.dataset.vf;
  const pm=btn.dataset.pm;
  const reset=btn.dataset.reset;
  const idx=parseInt(btn.dataset.idx);

  // Modales ouverture
  if(modal){ e.preventDefault(); openModal(modal); return; }
  // Modales fermeture
  if(close){ e.preventDefault(); closeModal(close); return; }
  // Navigation
  if(page){ e.preventDefault(); goTo(page); return; }
  // Filtres produits
  if(pf){ e.preventDefault(); prodFilter=pf; renderProds(); return; }
  // Filtres ventes
  if(vf){ e.preventDefault(); venteFilter=vf; renderVentes(); document.querySelectorAll('[data-vf]').forEach(el=>el.classList.toggle('ac',el.dataset.vf===vf)); return; }
  // Paiement caisse
  if(pm){ e.preventDefault(); caissePM=pm; document.querySelectorAll('[data-pm]').forEach(el=>el.classList.toggle('ac',el.dataset.pm===pm)); return; }
  // Reset données
  if(reset){ e.preventDefault(); doReset(reset); return; }

  // Actions spécifiques
  if(!action) return;
  e.preventDefault();

  switch(action){
    case 'edit-prod': openProdModal(idx); break;
    case 'del-prod': delProd(idx); break;
    case 'edit-vente': openVenteModal(idx); break;
    case 'del-vente': delVente(idx); break;
    case 'edit-fourn': openFournModal(idx); break;
    case 'del-fourn': delFourn(idx); break;
    case 'edit-client': openClientModal(idx); break;
    case 'del-client': delClient(idx); break;
    case 'hist-client': openClientHist(idx); break;
    case 'del-cmv': DATA.cmv.splice(idx,1); save(); renderFin(); break;
    case 'del-exp': DATA.depenses.splice(idx,1); save(); renderFin(); break;
    case 'del-rev': DATA.revenus.splice(idx,1); save(); renderFin(); break;
    case 'del-cat': delCat(idx); break;
    case 'caisse-add': caisseAdd(idx); break;
    case 'caisse-minus': caisseRemove(idx); break;
    case 'caisse-del': cart=cart.filter(i=>i.idx!==idx); renderCart(); renderCaisseProds(); break;
    case 'show-hist-detail':{
      const mIdx=parseInt(btn.dataset.midx);
      const year=parseInt(btn.dataset.year)||new Date().getFullYear();
      const months=Array.from({length:12},()=>({ventes:[],ca:0}));
      DATA.ventes.forEach(v=>{if(!v.rawDate)return;const d=new Date(v.rawDate);if(d.getFullYear()!==year)return;months[d.getMonth()].ventes.push(v);if(v.statut==='payee')months[d.getMonth()].ca+=v.montant;});
      showHistDetail(months,mIdx);
      break;
    }
    case 'calc-to-prod':{
      const name=prompt('Nom du produit :'); if(!name) return;
      try{ const d=JSON.parse(btn.dataset.data);
        DATA.produits.push({sku:'P-'+String(DATA.produits.length+1).padStart(4,'0'),name,cat:'autre',initial:parseInt($('c-qte-a').value)||1,vendu:0,prix:d.prixSug,prixAchat:d.coutUnit,fournisseur:'—',seuil:3,entree:today()});
        save(); renderProds(); toast('Produit "'+name+'" ajouté ✓');
      }catch(err){}
      break;
    }
  }
}

// Fermeture modales au clic fond
function handleBackdrop(e){
  if(e.target.classList.contains('mo')){
    e.target.classList.remove('on');
  }
}

// Appliquer les deux handlers sur click ET touchend
['click','touchend'].forEach(ev=>{
  document.addEventListener(ev, function(e){
    // NE PAS bloquer les champs de saisie
    const tag=e.target.tagName;
    if(tag==='INPUT'||tag==='SELECT'||tag==='TEXTAREA') return;
    if(ev==='touchend') e.preventDefault();
    handleAction(e);
    handleBackdrop(e);
  }, {passive:false});
});

/* ── BOUTONS AVEC ID (simples) ── */
function bindBtn(id, fn){
  const el=$(id); if(!el) return;
  el.addEventListener('click', fn);
  el.addEventListener('touchend', function(e){
    const tag=e.target.tagName;
    if(tag!=='INPUT'&&tag!=='SELECT'&&tag!=='TEXTAREA') e.preventDefault();
    fn(e);
  }, {passive:false});
}

