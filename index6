const MOIS_S=['Jan','Fév','Mar','Avr','Mai','Juin','Juil','Aoû','Sep','Oct','Nov','Déc'];

function initHistorique(){
  const years=new Set([new Date().getFullYear()]);
  DATA.ventes.forEach(v=>{ if(v.rawDate) years.add(new Date(v.rawDate).getFullYear()); });
  const sel=$('hist-year');
  if(sel){ sel.innerHTML=[...years].sort((a,b)=>b-a).map(y=>`<option value="${y}">${y}</option>`).join(''); }
  renderHistorique();
}

function renderHistorique(){
  const year=parseInt($('hist-year')?.value)||new Date().getFullYear();
  $('hist-year-label').textContent=year;
  const months=Array.from({length:12},()=>({ventes:[],ca:0}));
  DATA.ventes.forEach(v=>{
    if(!v.rawDate) return;
    const d=new Date(v.rawDate);
    if(d.getFullYear()!==year) return;
    months[d.getMonth()].ventes.push(v);
    if(v.statut==='payee') months[d.getMonth()].ca+=v.montant;
  });
  const totalCA=months.reduce((s,m)=>s+m.ca,0);
  const totalV=months.reduce((s,m)=>s+m.ventes.length,0);
  const actifs=months.filter(m=>m.ventes.length>0).length;
  const best=months.reduce((b,m,i)=>m.ca>b.ca?{ca:m.ca,idx:i}:b,{ca:0,idx:-1});
  $('hist-kpis').innerHTML=`
    <div class="kpi"><div class="kpi-l">CA annuel</div><div class="kpi-v" style="color:var(--green)">${fcfa(totalCA)}</div></div>
    <div class="kpi"><div class="kpi-l">Total ventes</div><div class="kpi-v">${totalV}</div></div>
    <div class="kpi"><div class="kpi-l">Mois actifs</div><div class="kpi-v">${actifs}/12</div></div>
    <div class="kpi"><div class="kpi-l">Moy/mois</div><div class="kpi-v" style="color:var(--blue)">${actifs>0?fcfa(Math.round(totalCA/actifs)):'—'}</div></div>
    <div class="kpi"><div class="kpi-l">Meilleur mois</div><div class="kpi-v" style="color:var(--yellow)">${best.idx>=0?MOIS_S[best.idx]:'—'}</div></div>
  `;
  // Chart
  const ctx=$('chart-hist');
  if(ctx){
    if(histChart) histChart.destroy();
    const data=months.map(m=>m.ca);
    const max=Math.max(...data,1);
    const tickFn=v=>max>=1e6?(v/1e6).toFixed(1)+'M':max>=1000?(v/1000).toFixed(0)+'k':v;
    histChart=new Chart(ctx,{type:'bar',data:{labels:MOIS_S,datasets:[{data,backgroundColor:data.map(v=>v>0?'rgba(42,120,214,.75)':'rgba(42,120,214,.15)'),borderRadius:6,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>' '+Math.round(c.raw).toLocaleString('fr-FR')+' FCFA'}}},scales:{x:{grid:{color:'rgba(80,130,255,.08)'},ticks:{color:'#6070a0',font:{size:10}}},y:{grid:{color:'rgba(80,130,255,.08)'},ticks:{color:'#6070a0',font:{size:10},callback:tickFn},beginAtZero:true}},onClick:(e,els)=>{if(els.length>0)showHistDetail(months,els[0].index);}}});
  }
  // Table
  $('hist-tbody').innerHTML=months.map((m,i)=>{
    const byP={};m.ventes.forEach(v=>{const k=(v.prodIdx!=null&&DATA.produits[v.prodIdx])?DATA.produits[v.prodIdx].name:v.desc;byP[k]=(byP[k]||0)+v.montant;});
    const top=Object.entries(byP).sort((a,b)=>b[1]-a[1])[0];
    const avg=m.ventes.filter(v=>v.statut==='payee').length>0?Math.round(m.ca/m.ventes.filter(v=>v.statut==='payee').length):0;
    return `<tr style="cursor:${m.ventes.length>0?'pointer':'default'}" ${m.ventes.length>0?`data-action="show-hist-detail" data-midx="${i}" data-year="${year}"`:''}>
      <td style="font-weight:500">${MOIS[i]}</td>
      <td>${m.ventes.length>0?`<span class="bdg bdg-b">${m.ventes.length}</span>`:'<span style="color:var(--tm)">—</span>'}</td>
      <td style="color:${m.ca>0?'var(--green)':'var(--tm)'};font-weight:${m.ca>0?'500':'400'}">${m.ca>0?fcfa(m.ca):'—'}</td>
      <td style="color:var(--blue)">${avg>0?fcfa(avg):'—'}</td>
      <td style="font-size:11px;color:var(--tm)">${top?top[0].slice(0,20):'—'}</td>
      <td>${m.ventes.length>0?`<button class="ib" data-action="show-hist-detail" data-midx="${i}" data-year="${year}"><i class="ti ti-eye"></i></button>`:''}</td>
    </tr>`;
  }).join('');
  $('hist-detail').style.display='none';
}

function showHistDetail(months, mIdx){
  const m=months[mIdx];
  const year=$('hist-year')?.value||new Date().getFullYear();
  $('hist-detail-title').textContent=MOIS[mIdx]+' '+year;
  const sorted=[...m.ventes].sort((a,b)=>new Date(b.rawDate||0)-new Date(a.rawDate||0));
  $('hist-detail-tbody').innerHTML=sorted.length===0
    ?'<tr><td colspan="6" style="text-align:center;color:var(--tm);padding:16px">Aucune vente.</td></tr>'
    :sorted.map(v=>`<tr><td>${v.num}</td><td>${v.client}</td><td style="font-size:11px">${v.desc.slice(0,25)}</td><td style="color:var(--green)">${fcfa(v.montant)}</td><td><span class="bdg ${v.statut==='payee'?'bdg-g':'bdg-y'}">${v.statut}</span></td><td style="font-size:11px">${v.date}</td></tr>`).join('')
    +`<tr style="background:rgba(80,130,255,.06)"><td colspan="3" style="font-weight:600">Total payé</td><td colspan="3" style="font-weight:600;color:var(--green)">${fcfa(m.ca)}</td></tr>`;
  $('hist-detail').style.display='block';
  setTimeout(()=>$('hist-detail').scrollIntoView({behavior:'smooth',block:'start'}),100);
}

