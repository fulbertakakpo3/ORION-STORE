<!-- Import file input -->
<input type="file" id="import-input" accept=".json" style="display:none"/>

<script>
'use strict';
/* ═══════════════════════════════════════════════════════════════
   MY STORE MANAGER — v5.0
   Architecture propre : event delegation, window scope, touch+click
═══════════════════════════════════════════════════════════════ */

/* ── DATA ── */
const SHOP_NAME = 'MY STORE MANAGER';
let DATA = {
  shop: SHOP_NAME, owner:'', phone:'', email:'',
  devise:'FCFA', tax:0, objectifCA:0, seuilRent:0, margeTarget:30, stockSeuil:5,
  produits:[], fournisseurs:[], clients:[], ventes:[], cmv:[], depenses:[], revenus:[],
  cats:[
    {id:'meubles',   label:'Meubles',          secteur:'deco', color:'#2a78d6', icon:'ti-armchair'},
    {id:'luminaires',label:'Luminaires',        secteur:'deco', color:'#f59e0b', icon:'ti-bulb'},
    {id:'textile',   label:'Textile & Coussins',secteur:'deco', color:'#8b5cf6', icon:'ti-rug'},
    {id:'deco',      label:'Déco & Art',        secteur:'deco', color:'#ec4899', icon:'ti-plant'},
    {id:'vaisselle', label:'Vaisselle',          secteur:'deco', color:'#14b8a6', icon:'ti-bowl'},
    {id:'autre',     label:'Autre',              secteur:'general', color:'#6b7280', icon:'ti-tag'},
  ],
  calcHist:[], venteCpt:1
};

// Variable locale pour calcHist (sync avec DATA)
let calcHist = DATA.calcHist;

/* ── UTILS ── */
const $ = id => document.getElementById(id);
const fcfa = n => Math.round(n||0).toLocaleString('fr-FR') + ' ' + (DATA.devise||'FCFA');
const today = () => new Date().toLocaleDateString('fr-FR');
const nowISO = () => new Date().toISOString();
function getCat(id){ return DATA.cats.find(c=>c.id===id)||{id,label:id,color:'#6b7280',icon:'ti-tag'}; }

/* ── TOAST ── */
function toast(msg, type='ok'){
  const w = $('toast-wrap');
  if(!w) return;
  const t = document.createElement('div');
  const bg = type==='err'?'#c0392b':type==='warn'?'#b7860a':'#1a7a50';
  t.style.cssText=`background:${bg};color:#fff;padding:10px 18px;border-radius:20px;font-size:13px;font-weight:500;box-shadow:0 4px 14px rgba(0,0,0,.3);opacity:0;transform:translateY(10px);transition:all .2s;white-space:nowrap;max-width:90vw;text-align:center`;
  t.textContent=msg; w.appendChild(t);
  requestAnimationFrame(()=>{t.style.opacity='1';t.style.transform='translateY(0)'});
  setTimeout(()=>{t.style.opacity='0';t.style.transform='translateY(10px)';setTimeout(()=>t.remove(),200)},2800);
}

/* ── SAVE / LOAD ── */
const LS='mystore_v5';
function save(){ try{localStorage.setItem(LS,JSON.stringify(DATA))}catch(e){} }
function load(){
  try{
    const r=localStorage.getItem(LS);
    if(!r) return false;
    const d=JSON.parse(r);
    Object.assign(DATA,d);
    calcHist=DATA.calcHist; // resync après chargement
    return true;
  }catch(e){return false;}
}

/* ── MODAL SYSTEM ── */
function openModal(id){
  const el=$(id); if(!el) return;
  el.classList.add('on');
  // Pré-remplir certaines modales
  if(id==='m-prod') { buildCatSelect(); }
  if(id==='m-vente') { buildVenteProdSelect(); $('v-date').value=new Date().toISOString().split('T')[0]; }
  if(id==='m-cats') renderCatsList();
}
function closeModal(id){ const el=$(id); if(el) el.classList.remove('on'); }
function openDel(msg, cb){
  $('m-del-msg').textContent=msg;
  delCb=cb;
  openModal('m-del');
}
let delCb=null;

/* ── NAVIGATION ── */
let curPage='dashboard';
const PAGE_ACTIONS={
  dashboard:'Nouvelle vente', caisse:null, ventes:'Nouvelle facture',
  produits:'Ajouter produit', fournisseurs:'Ajouter fournisseur',
  clients:'Ajouter client', finances:null, calcul:null,
  rapports:null, historique:null, settings:null
};

function goTo(page){
  if(page===curPage && document.getElementById('sb')?.classList.contains('open')) { closeSb(); return; }
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  const pg=$(`page-${page}`); if(pg) pg.classList.add('on');
  document.querySelectorAll('.ni[data-page], .bn-btn[data-page]').forEach(el=>{
    el.classList.toggle('ac', el.dataset.page===page);
  });
  const lbl=PAGE_ACTIONS[page];
  const addBtn=$('top-add');
  if(addBtn){ addBtn.style.display=lbl?'':'none'; if(lbl) $('top-add-label').textContent=lbl; }
  curPage=page;
  closeSb();
  // Init pages
  if(page==='dashboard') renderDash();
  if(page==='caisse') initCaisse();
  if(page==='ventes') renderVentes();
  if(page==='produits') renderProds();
  if(page==='fournisseurs') renderFourn();
  if(page==='clients') renderClients();
  if(page==='finances') renderFin();
  if(page==='rapports') renderRapports();
  if(page==='historique') initHistorique();
}

function topAddAction(){
  if(curPage==='dashboard'||curPage==='ventes') openVenteModal();
  else if(curPage==='produits') openProdModal();
  else if(curPage==='fournisseurs') openFournModal();
  else if(curPage==='clients') openClientModal();
}

/* ── SIDEBAR ── */
function openSb(){ $('sb').classList.add('open'); $('overlay').classList.add('on'); }
function closeSb(){ $('sb').classList.remove('open'); $('overlay').classList.remove('on'); }
function toggleSb(){ $('sb').classList.contains('open')?closeSb():openSb(); }

/* ── SEARCH ── */
function doSearch(q){
  q=q.trim().toLowerCase(); if(q.length<2) return;
  const p=DATA.produits.find(p=>p.name.toLowerCase().includes(q)||p.sku.toLowerCase().includes(q));
  if(p){ goTo('produits'); toast('Produit trouvé : '+p.name); return; }
  const v=DATA.ventes.find(v=>v.client.toLowerCase().includes(q)||v.num.toLowerCase().includes(q));
  if(v){ goTo('ventes'); toast('Facture trouvée : '+v.num); return; }
  const c=DATA.clients.find(c=>c.nom.toLowerCase().includes(q));
  if(c){ goTo('clients'); toast('Client trouvé : '+c.nom); return; }
  toast('Aucun résultat pour "'+q+'"','warn');
}

/* ════════════════════════════════════════
   DASHBOARD
════════════════════════════════════════ */
let chartSales=null;
function renderDash(){
  const ventes=DATA.ventes;
  const payees=ventes.filter(v=>v.statut==='payee');
  const CA=payees.reduce((s,v)=>s+v.montant,0);
  const CMV=sumCMV();
  const dep=DATA.depenses.reduce((s,e)=>s+e.montant,0);
  const rev=DATA.revenus.reduce((s,e)=>s+e.montant,0);
  const benef=CA+rev-CMV-dep;
  const restant=DATA.produits.reduce((s,p)=>s+(p.initial-p.vendu),0);

  $('dash-kpis').innerHTML=`
    <div class="kpi"><div class="kpi-l">CA total</div><div class="kpi-v" style="color:var(--green)">${fcfa(CA)}</div><div class="kpi-s" style="color:var(--tm)">${payees.length} facture(s)</div></div>
    <div class="kpi"><div class="kpi-l">Bénéfice net</div><div class="kpi-v" style="color:${benef>=0?'var(--green)':'var(--red)'}">${fcfa(benef)}</div><div class="kpi-s" style="color:var(--tm)">CA − CMV − Dép.</div></div>
    <div class="kpi"><div class="kpi-l">CMV</div><div class="kpi-v" style="color:var(--yellow)">${fcfa(CMV)}</div><div class="kpi-s" style="color:var(--tm)">Coût marchandises</div></div>
    <div class="kpi"><div class="kpi-l">Dépenses</div><div class="kpi-v" style="color:var(--red)">${fcfa(dep)}</div><div class="kpi-s" style="color:var(--tm)">${DATA.depenses.length} entrée(s)</div></div>
    <div class="kpi"><div class="kpi-l">Stock restant</div><div class="kpi-v">${restant}</div><div class="kpi-s" style="color:var(--tm)">${DATA.produits.length} référence(s)</div></div>
    <div class="kpi"><div class="kpi-l">Marge nette</div><div class="kpi-v" style="color:${benef>=0?'var(--green)':'var(--red)'}">${CA>0?Math.round(benef/CA*100):0}%</div><div class="kpi-s" style="color:var(--tm)">Bén. net / CA</div></div>
  `;

  // Table bénéfice par produit
  const rows=DATA.produits.filter(p=>p.vendu>0).map(p=>{
    const totalCA=p.prix*p.vendu, totalCost=(p.prixAchat||0)*p.vendu;
    const depUnit=DATA.depenses.length>0?Math.round(dep/Math.max(1,DATA.produits.filter(x=>x.vendu>0).reduce((s,x)=>s+x.vendu,0))):0;
    const benUnit=p.prix-(p.prixAchat||0)-depUnit;
    const marge=p.prix>0?Math.round(benUnit/p.prix*100):0;
    return `<tr><td>${p.name}</td><td>${p.vendu}</td><td>${fcfa(p.prix)}</td><td style="color:var(--yellow)">${fcfa(p.prixAchat||0)}</td><td style="color:${benUnit>=0?'var(--green)':'var(--red)'}">${fcfa(benUnit*p.vendu)}</td><td><span class="bdg ${marge>=0?'bdg-g':'bdg-r'}">${marge}%</span></td></tr>`;
  }).join('');
  $('dash-prod-table').innerHTML=rows||'<tr><td colspan="6" style="text-align:center;color:var(--tm);padding:16px">Aucun produit vendu.</td></tr>';

  // Alertes stock
  const critiques=DATA.produits.filter(p=>(p.initial-p.vendu)<=p.seuil&&p.seuil>0);
  $('dash-stock-alert').innerHTML=critiques.length===0
    ?'<div style="color:var(--green);font-size:13px;padding:8px"><i class="ti ti-circle-check"></i> Stocks suffisants.</div>'
    :critiques.map(p=>`<div style="display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(80,130,255,.08);font-size:12px"><span>${p.name}</span><span class="bdg bdg-r">${p.initial-p.vendu} u.</span></div>`).join('');

  // Dernières ventes
  const recent=[...ventes].sort((a,b)=>new Date(b.rawDate||0)-new Date(a.rawDate||0)).slice(0,5);
  $('dash-recent-sales').innerHTML=recent.length===0
    ?'<div style="color:var(--tm);font-size:13px;padding:8px">Aucune vente.</div>'
    :recent.map(v=>`<div style="display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(80,130,255,.08);font-size:12px"><span>${v.num} · ${v.client}</span><span style="color:var(--green)">${fcfa(v.montant)}</span></div>`).join('');

  // Graphique
  updateSalesChart();
}

function getSalesData(){
  const months=Array(6).fill(0);
  const now=new Date();
  DATA.ventes.filter(v=>v.statut==='payee'&&v.rawDate).forEach(v=>{
    const d=new Date(v.rawDate);
    const diff=(now.getFullYear()-d.getFullYear())*12+(now.getMonth()-d.getMonth());
    if(diff>=0&&diff<6) months[5-diff]+=v.montant;
  });
  const labels=[];
  const mn=['Jan','Fév','Mar','Avr','Mai','Juin','Juil','Aoû','Sep','Oct','Nov','Déc'];
  for(let i=5;i>=0;i--){ const d=new Date(now.getFullYear(),now.getMonth()-i,1); labels.push(mn[d.getMonth()]); }
  return {labels,data:months};
}

function updateSalesChart(){
  const ctx=$('chart-sales'); if(!ctx) return;
  const {labels,data}=getSalesData();
  const max=Math.max(...data,1);
  const tickFn=v=>max>=1e6?(v/1e6).toFixed(1)+'M':max>=1000?(v/1000).toFixed(0)+'k':v;
  if(chartSales) chartSales.destroy();
  chartSales=new Chart(ctx,{type:'bar',data:{labels,datasets:[{label:'CA',data,backgroundColor:data.map(v=>v>0?'rgba(42,120,214,.75)':'rgba(42,120,214,.15)'),borderRadius:6,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>' '+Math.round(c.raw).toLocaleString('fr-FR')+' FCFA'}}},scales:{x:{grid:{color:'rgba(80,130,255,.08)'},ticks:{color:'#6070a0',font:{size:11}}},y:{grid:{color:'rgba(80,130,255,.08)'},ticks:{color:'#6070a0',font:{size:11},callback:tickFn},beginAtZero:true}}}});
}

