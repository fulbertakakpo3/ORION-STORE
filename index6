function doCalc(){
  const achat=parseFloat($('c-achat').value)||0;
  const qteA=parseInt($('c-qte-a').value)||1;
  const frais=parseFloat($('c-frais').value)||0;
  const marge=parseFloat($('c-marge').value)||30;
  const vente=parseFloat($('c-vente').value)||0;
  const qteV=parseInt($('c-qte-v').value)||0;
  if(!achat){toast('Entrez un prix d\'achat.','err');return;}
  const coutUnit=(achat*qteA+frais)/qteA;
  const prixSug=vente||Math.round(coutUnit*(1+marge/100));
  const benefUnit=prixSug-coutUnit;
  const benefTotal=benefUnit*qteV;
  const margeReel=prixSug>0?Math.round(benefUnit/prixSug*100):0;
  const res=$('calc-result');
  res.style.display='block';
  res.innerHTML=`
    <div style="font-size:12px;font-weight:500;margin-bottom:12px;color:var(--blue)"><i class="ti ti-calculator"></i> Résultats</div>
    <div class="trow"><span>Coût unitaire réel</span><span style="color:var(--yellow)">${fcfa(coutUnit)}</span></div>
    <div class="trow"><span>Prix de vente suggéré</span><span style="color:var(--green);font-weight:600">${fcfa(prixSug)}</span></div>
    <div class="trow"><span>Bénéfice / unité</span><span style="color:${benefUnit>=0?'var(--green)':'var(--red)'}">${fcfa(benefUnit)}</span></div>
    <div class="trow"><span>Marge réelle</span><span style="color:${margeReel>=0?'var(--green)':'var(--red)'}">${margeReel}%</span></div>
    ${qteV>0?`<div class="trow"><span>Bénéfice total (${qteV}u)</span><span style="color:${benefTotal>=0?'var(--green)':'var(--red)'};font-weight:600">${fcfa(benefTotal)}</span></div>`:''}
    <button class="btn btn-p mt-12" data-action="calc-to-prod" data-data='${JSON.stringify({coutUnit,prixSug,margeReel})}' style="width:100%;justify-content:center"><i class="ti ti-box"></i> Ajouter au catalogue</button>
  `;
  calcHist=DATA.calcHist;
  calcHist.unshift({date:today(),achat,qteA,frais,marge,prixSug,benefUnit,margeReel});
  save();
  renderCalcHist();
}

function renderCalcHist(){
  const el=$('calc-hist');if(!el)return;
  el.innerHTML=calcHist.length===0
    ?'<div style="color:var(--tm);font-size:12px;text-align:center;padding:16px">Aucun calcul.</div>'
    :calcHist.slice(0,10).map((h,i)=>`<div class="trow" style="font-size:11px">
      <span style="color:var(--tm)">${h.date} — Achat ${fcfa(h.achat)}</span>
      <span style="color:var(--green)">${fcfa(h.prixSug)} · ${h.margeReel}%</span>
    </div>`).join('');
}

