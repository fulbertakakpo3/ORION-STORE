function exportCSV(type){
  let rows=[],fn='';
  if(type==='ventes'){rows=[['N°','Client','Description','Montant','Statut','Paiement','Date'],...DATA.ventes.map(v=>[v.num,v.client,v.desc,v.montant,v.statut,v.paiement||'',v.date])];fn='ventes.csv';}
  else if(type==='stock'){rows=[['SKU','Nom','Catégorie','Stock','Vendu','Prix vente','Prix achat','Fournisseur'],...DATA.produits.map(p=>[p.sku,p.name,getCat(p.cat).label,p.initial,p.vendu,p.prix,p.prixAchat||0,p.fournisseur||''])];fn='stock.csv';}
  else if(type==='clients'){rows=[['Nom','Tel','Email','Achats','Total','Notes'],...DATA.clients.map(c=>[c.nom,c.tel||'',c.email||'',c.achats||0,c.total||0,c.note||''])];fn='clients.csv';}
  const csv=rows.map(r=>r.map(v=>'"'+String(v).replace(/"/g,'""')+'"').join(',')).join('\n');
  dl(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'}),fn);
  toast('Export CSV téléchargé ✓');
}

function exportJSON(){
  dl(new Blob([JSON.stringify(DATA,null,2)],{type:'application/json'}),'mystore_backup_'+new Date().toISOString().slice(0,10)+'.json');
  toast('Backup JSON téléchargé ✓');
}

function importJSON(){ $('import-input').click(); }

function handleImport(e){
  const file=e.target.files[0]; if(!file) return;
  const r=new FileReader();
  r.onload=ev=>{
    try{
      const d=JSON.parse(ev.target.result);
      Object.assign(DATA,d); save();
      renderDash();renderProds();renderVentes();renderFourn();renderClients();renderFin();
      buildCatSelect();renderProdFilters();
      toast('Import réussi ✓');
    }catch(err){toast('Fichier invalide.','err');}
  };
  r.readAsText(file);
  e.target.value='';
}

function exportPDF(){
  const CA=DATA.ventes.filter(v=>v.statut==='payee').reduce((s,v)=>s+v.montant,0);
  const CMV=sumCMV(),dep=DATA.depenses.reduce((s,e)=>s+e.montant,0),benef=CA-CMV-dep;
  const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${DATA.shop}</title>
  <style>body{font-family:Arial,sans-serif;padding:40px;color:#1a1a2e}h1{color:#1e40af}table{width:100%;border-collapse:collapse;margin:16px 0}th{background:#eff6ff;padding:8px;text-align:left;font-size:12px}td{padding:8px;border-bottom:1px solid #e2e8f0;font-size:13px}.kpis{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:16px 0}.kpi{background:#f8fafc;border-radius:8px;padding:14px}.kv{font-size:20px;font-weight:600}.kl{font-size:11px;color:#64748b}</style>
  </head><body><h1>${DATA.shop}</h1><p style="color:#64748b">Rapport généré le ${today()}</p>
  <div class="kpis"><div class="kpi"><div class="kl">CA Total</div><div class="kv" style="color:#16a34a">${fcfa(CA)}</div></div><div class="kpi"><div class="kl">Bénéfice Net</div><div class="kv" style="color:${benef>=0?'#16a34a':'#dc2626'}">${fcfa(benef)}</div></div><div class="kpi"><div class="kl">Ventes</div><div class="kv">${DATA.ventes.length}</div></div></div>
  <h2>Ventes</h2><table><tr><th>N°</th><th>Client</th><th>Description</th><th>Montant</th><th>Statut</th><th>Date</th></tr>${DATA.ventes.map(v=>`<tr><td>${v.num}</td><td>${v.client}</td><td>${v.desc}</td><td>${fcfa(v.montant)}</td><td>${v.statut}</td><td>${v.date}</td></tr>`).join('')}</table>
  <h2>Résumé financier</h2><table><tr><th>Élément</th><th>Montant</th></tr><tr><td>CA</td><td>${fcfa(CA)}</td></tr><tr><td>CMV</td><td>−${fcfa(CMV)}</td></tr><tr><td>Dépenses</td><td>−${fcfa(dep)}</td></tr><tr><td><strong>Bénéfice net</strong></td><td><strong>${fcfa(benef)}</strong></td></tr></table>
  </body></html>`;
  const w=window.open('','_blank');w.document.write(html);w.document.close();setTimeout(()=>w.print(),500);
