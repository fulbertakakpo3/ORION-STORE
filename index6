function doReset(type){
  const msgs={produits:'Supprimer tous les produits ?',fournisseurs:'Supprimer tous les fournisseurs ?',clients:'Supprimer tous les clients ?',ventes:'Supprimer toutes les ventes ?',tout:'Tout remettre à zéro ?'};
  openDel(msgs[type]||'Remettre à zéro ?',()=>{
    if(type==='tout'||type==='produits'){DATA.produits=[];DATA.venteCpt=1;}
    if(type==='tout'||type==='fournisseurs') DATA.fournisseurs=[];
    if(type==='tout'||type==='clients') DATA.clients=[];
