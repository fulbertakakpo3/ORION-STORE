function sumCMV(){
  let auto=0;
  DATA.ventes.filter(v=>v.statut==='payee').forEach(v=>{
    if(v.prodIdx!=null&&DATA.produits[v.prodIdx]?.prixAchat>0)
      auto+=DATA.produits[v.prodIdx].prixAchat*(v.qte||0);
  });
  return auto+DATA.cmv.reduce((s,e)=>s+e.montant,0);
}

