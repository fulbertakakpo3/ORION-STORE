function renderRapports(){
  const CA=DATA.ventes.filter(v=>v.statut==='payee').reduce((s,v)=>s+v.montant,0);
  const obj=DATA.objectifCA||0;
  const pct=obj>0?Math.min(100,Math.round(CA/obj*100)):0;

  $('rpt-obj-kpis').innerHTML=`
    <div class="kpi"><div class="kpi-l">Objectif</div><div class="kpi-v" style="color:var(--blue)">${obj>0?fcfa(obj):'—'}</div></div>
    <div class="kpi"><div class="kpi-l">CA réalisé</div><div class="kpi-v" style="color:var(--green)">${fcfa(CA)}</div></div>
    <div class="kpi"><div class="kpi-l">Progression</div><div class="kpi-v" style="color:${pct>=100?'var(--green)':pct>=60?'var(--yellow)':'var(--red)'}">${obj>0?pct+'%':'—'}</div></div>
  `;
  $('rpt-obj-bar').style.width=pct+'%';
  $('rpt-obj-bar').style.background=pct>=100?'var(--green)':pct>=60?'var(--yellow)':'var(--blue)';
  $('rpt-obj-msg').textContent=obj>0?(pct>=100?'🎉 Objectif atteint !':`Il manque ${fcfa(obj-CA)}.`):'Définissez un objectif dans les paramètres.';

  // Alertes
  const alerts=[];
  const critique=DATA.produits.filter(p=>(p.initial-p.vendu)<=p.seuil&&p.seuil>0);
  if(critique.length>0) alerts.push({icon:'ti-alert-triangle',col:'var(--red)',msg:`${critique.length} produit(s) en stock critique.`});
  const unsold=DATA.produits.filter(p=>p.vendu===0&&p.initial>0);
  if(unsold.length>0) alerts.push({icon:'ti-clock',col:'var(--yellow)',msg:`${unsold.length} produit(s) jamais vendus.`});
  const impaye=DATA.ventes.filter(v=>v.statut==='attente');
  if(impaye.length>0) alerts.push({icon:'ti-clock-exclamation',col:'var(--red)',msg:`${impaye.length} facture(s) impayée(s) — ${fcfa(impaye.reduce((s,v)=>s+v.montant,0))}.`});
  const CMV=sumCMV();
  if(CA>0&&CMV/CA>0.6) alerts.push({icon:'ti-trending-down',col:'var(--yellow)',msg:`CMV élevé : ${Math.round(CMV/CA*100)}% du CA.`});
  if(obj>0&&CA>=obj) alerts.push({icon:'ti-trophy',col:'var(--green)',msg:`Objectif CA atteint ! ${fcfa(CA)}.`});
  $('rpt-alertes').innerHTML=alerts.length===0
    ?'<div style="color:var(--green);padding:12px;font-size:13px"><i class="ti ti-circle-check"></i> Tout est en ordre !</div>'
    :alerts.map(a=>`<div style="display:flex;align-items:flex-start;gap:10px;padding:10px;background:var(--bg2);border-radius:8px;margin-bottom:6px;font-size:13px"><i class="ti ${a.icon}" style="color:${a.col};flex-shrink:0"></i><span>${a.msg}</span></div>`).join('');

  // Top 5
  const byProd={};
  DATA.ventes.filter(v=>v.statut==='payee').forEach(v=>{ const k=v.desc||v.client; byProd[k]=(byProd[k]||0)+v.montant; });
  const top=Object.entries(byProd).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const maxCA=top[0]?.[1]||1;
  $('rpt-top5').innerHTML=top.length===0
    ?'<div style="color:var(--tm);font-size:13px;text-align:center;padding:16px">Aucune vente.</div>'
    :top.map(([n,ca],i)=>`<div style="margin-bottom:10px"><div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px"><span>${i+1}. ${n.slice(0,25)}</span><span style="color:var(--green)">${fcfa(ca)}</span></div><div class="pbar"><div class="pbar-fill" style="width:${Math.round(ca/maxCA*100)}%;background:var(--blue)"></div></div></div>`).join('');

  $('rpt-unsold').innerHTML=unsold.length===0
    ?'<div style="color:var(--green);font-size:13px;text-align:center;padding:16px"><i class="ti ti-circle-check"></i> Tous vendus !</div>'
    :unsold.slice(0,5).map(p=>`<div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid rgba(80,130,255,.08);font-size:12px"><span>${p.name}</span><span style="color:var(--tm)">${p.initial} en stock</span></div>`).join('');
}

