}

function renderCaisseProds(){
  const q=($('caisse-search')?.value||'').toLowerCase();
  const cat=$('caisse-cat')?.value||'';
  const prods=DATA.produits.filter(p=>{
    if((p.initial-p.vendu)<=0) return false;
    if(cat&&p.cat!==cat) return false;
    if(q&&!p.name.toLowerCase().includes(q)) return false;
    return true;
  });
  const el=$('caisse-prods'); if(!el) return;
  if(prods.length===0){ el.innerHTML='<div style="grid-column:1/-1;text-align:center;color:var(--tm);padding:30px;font-size:13px">Aucun produit disponible.</div>'; return; }
  el.innerHTML=prods.map(p=>{
    const idx=DATA.produits.indexOf(p);
    const cat=getCat(p.cat);
    const inCart=cart.find(it=>it.idx===idx);
    return `<div class="prod-card ${inCart?'in-cart':''}" data-action="caisse-add" data-idx="${idx}">
      <div class="prod-card-icon" style="background:${cat.color}20"><i class="ti ${cat.icon}" style="color:${cat.color};font-size:18px"></i></div>
      <div style="font-size:12px;font-weight:600;margin-bottom:4px;line-height:1.3">${p.name}</div>
      <div style="font-size:13px;font-weight:600;color:var(--green)">${fcfa(p.prix)}</div>
      <div style="font-size:10px;color:var(--tm)">Stock: ${p.initial-p.vendu}</div>
      ${inCart?`<div style="font-size:10px;color:var(--blue);margin-top:4px"><i class="ti ti-check"></i> ${inCart.qte} dans panier</div>`:''}
    </div>`;
  }).join('');
}

function caisseAdd(idx){
  const p=DATA.produits[idx]; if(!p) return;
  const rest=p.initial-p.vendu;
  const it=cart.find(i=>i.idx===idx);
  if(it){ if(it.qte>=rest){toast('Stock insuffisant','warn');return;} it.qte++; }
  else cart.push({idx,qte:1,prix:p.prix,nom:p.name});
  renderCart(); renderCaisseProds();
}

function caisseRemove(idx){
  const it=cart.find(i=>i.idx===idx);
  if(!it) return;
  if(it.qte>1) it.qte--; else cart=cart.filter(i=>i.idx!==idx);
  renderCart(); renderCaisseProds();
}

function caisseClear(){ cart=[]; renderCart(); renderCaisseProds(); }

function renderCart(){
  const el=$('caisse-cart'); if(!el) return;
  const emp=$('caisse-empty');
  if(cart.length===0){ el.innerHTML='<div id="caisse-empty" style="text-align:center;color:var(--tm);padding:24px;font-size:12px"><i class="ti ti-shopping-cart-off" style="font-size:28px;display:block;margin-bottom:8px;opacity:.3"></i>Panier vide</div>'; }
  else {
    el.innerHTML=cart.map(it=>`
      <div class="cart-item">
        <div style="flex:1"><div style="font-size:12px;font-weight:500">${it.nom}</div><div style="font-size:11px;color:var(--green)">${fcfa(it.prix)} × ${it.qte} = ${fcfa(it.prix*it.qte)}</div></div>
        <div style="display:flex;gap:4px;align-items:center">
          <button class="ib" style="width:24px;height:24px;font-size:11px" data-action="caisse-minus" data-idx="${it.idx}"><i class="ti ti-minus"></i></button>
          <span style="font-size:13px;font-weight:500;min-width:18px;text-align:center">${it.qte}</span>
          <button class="ib" style="width:24px;height:24px;font-size:11px" data-action="caisse-add" data-idx="${it.idx}"><i class="ti ti-plus"></i></button>
          <button class="ib ib-d" style="width:24px;height:24px;font-size:11px" data-action="caisse-del" data-idx="${it.idx}"><i class="ti ti-x"></i></button>
        </div>
      </div>`).join('');
  }
  const remise=parseFloat($('caisse-remise')?.value)||0;
  const sub=cart.reduce((s,it)=>s+it.prix*it.qte,0);
  const total=Math.max(0,sub-remise);
  $('caisse-count').textContent=cart.reduce((n,it)=>n+it.qte,0)+' article(s)';
  $('caisse-subtotal').textContent=fcfa(sub);
  $('caisse-total').textContent=fcfa(total);
}

function encaisser(){
  if(cart.length===0){toast('Panier vide.','warn');return;}
  const remise=parseFloat($('caisse-remise')?.value)||0;
  const sub=cart.reduce((s,it)=>s+it.prix*it.qte,0);
  const total=Math.max(0,sub-remise);
  const clientSel=$('caisse-client');
  const clientNom=clientSel?.value?DATA.clients[parseInt(clientSel.value)]?.nom:'Passage';
  const pm=['especes','mobile','carte'].find(p=>p===caissePM)||'especes';
  const pmL={especes:'Espèces',mobile:'Mobile Money',carte:'Carte'}[pm];
  const num='F-'+String(DATA.venteCpt++).padStart(4,'0');
  const desc=cart.map(it=>it.nom+'×'+it.qte).join(', ');
  cart.forEach(it=>{ if(DATA.produits[it.idx]) DATA.produits[it.idx].vendu+=it.qte; });
  DATA.ventes.push({num,client:clientNom,desc,montant:total,statut:'payee',paiement:pmL,qte:cart.reduce((n,it)=>n+it.qte,0),prodIdx:cart.length===1?cart[0].idx:null,date:today(),rawDate:nowISO(),remise});
  if(clientSel?.value){ const cl=DATA.clients[parseInt(clientSel.value)]; if(cl){cl.achats=(cl.achats||0)+1;cl.total=(cl.total||0)+total;} }
  save(); cart=[]; renderCart(); renderCaisseProds(); if($('caisse-remise')) $('caisse-remise').value='0';
  renderVentes(); renderDash(); updateSalesChart();
  toast(`✓ ${num} — ${fcfa(total)} encaissé`);
}

